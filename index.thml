<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Anime Tracker</title>

<style>

body{
font-family:Arial;
background:#0f172a;
color:white;
text-align:center;
}

h1{
margin-top:20px;
}

input,textarea{
padding:10px;
margin:5px;
border-radius:8px;
border:none;
width:200px;
}

button{
padding:10px;
border:none;
border-radius:8px;
background:#6366f1;
color:white;
cursor:pointer;
}

#liste{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
padding:20px;
}

.anime{
background:#1e293b;
padding:15px;
border-radius:12px;
}

.anime img{
width:100%;
border-radius:10px;
}

</style>

</head>

<body>

<h1>🎌 Anime Tracker</h1>

<input id="nom" placeholder="Nom de l'animé">
<input id="note" type="number" min="0" max="10" placeholder="Note /10">
<input id="image" placeholder="URL image">

<br>

<textarea id="commentaire" placeholder="Commentaire"></textarea>

<br>

<button onclick="ajouter()">Ajouter</button>

<br><br>

<input id="recherche" placeholder="Rechercher..." onkeyup="afficher()">

<div id="liste"></div>

<script>

let animes = JSON.parse(localStorage.getItem("animes")) || [];

function save(){
localStorage.setItem("animes",JSON.stringify(animes));
}

function ajouter(){

let nom=document.getElementById("nom").value;
let note=document.getElementById("note").value;
let image=document.getElementById("image").value;
let commentaire=document.getElementById("commentaire").value;

if(nom==="") return;

animes.push({
nom,
note,
image,
commentaire
});

save();
afficher();

document.getElementById("nom").value="";
document.getElementById("note").value="";
document.getElementById("image").value="";
document.getElementById("commentaire").value="";

}

function supprimer(i){

animes.splice(i,1);
save();
afficher();

}

function afficher(){

let recherche=document.getElementById("recherche").value.toLowerCase();

let html="";

animes.forEach((a,i)=>{

if(a.nom.toLowerCase().includes(recherche)){

html+=`

<div class="anime">

<img src="${a.image}" onerror="this.style.display='none'">

<h3>${a.nom}</h3>

⭐ ${a.note}/10

<p>${a.commentaire}</p>

<button onclick="supprimer(${i})">Supprimer</button>

</div>

`;

}

});

document.getElementById("liste").innerHTML=html;

}

afficher();

</script>

</body>
</html>
