<!DOCTYPE html>
<html>
<head>
<title>Mes livres</title>
<style>
body{font-family:Arial;padding:20px;background:#f5f5f5}
.book{background:white;padding:10px;margin:10px 0;border-radius:8px}
img{width:100px}
</style>
</head>
<body>

<h1>Mes livres lus 📚</h1>

<input id="title" placeholder="Titre du livre"><br><br>
<input id="image" placeholder="URL image"><br><br>
<input id="rating" placeholder="Note /10"><br><br>
<textarea id="comment" placeholder="Commentaire"></textarea><br><br>

<button onclick="addBook()">Ajouter</button>

<h2>Ma bibliothèque</h2>

<div id="books"></div>

<script>
let books = JSON.parse(localStorage.getItem("books")) || [];

function render(){
document.getElementById("books").innerHTML="";
books.forEach(b=>{
document.getElementById("books").innerHTML += `
<div class="book">
<h3>${b.title}</h3>
<img src="${b.image}">
<p><b>Note:</b> ${b.rating}</p>
<p>${b.comment}</p>
</div>
`;
});
}

function addBook(){
let book={
title:document.getElementById("title").value,
image:document.getElementById("image").value,
rating:document.getElementById("rating").value,
comment:document.getElementById("comment").value
};
books.unshift(book);
localStorage.setItem("books",JSON.stringify(books));
render();
}

render();
</script>

</body>
</html>
